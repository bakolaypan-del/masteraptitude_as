{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "../server.ts,../firebase-applet-config.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/|assets/|favicon.ico|manifest.json).*)",
      "destination": "/index.html"
    }
  ]
}

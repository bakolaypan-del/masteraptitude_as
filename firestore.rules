rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /profiles/{userId} {
      // User can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // User can create their profile but NOT their role or score
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['role'])
        && request.resource.data.role == 'user'
        && (!('totalTestsTaken' in request.resource.data) || request.resource.data.totalTestsTaken == 0)
        && (!('cumulativeScore' in request.resource.data) || request.resource.data.cumulativeScore == 0);

      // User can only update name/email/phone, NOT role or score
      allow update: if (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email', 'phoneNumber'])) || isAdmin();
    }

    match /tests/{testId} {
      // Users can only read active tests. Admins can read all.
      // We check resource.data.isActive for document read, but how for list? 
      // The query must strictly include `where('isActive', '==', true)`
      allow read: if isSignedIn() && (resource.data.isActive == true || isAdmin());
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      // Backend API handles questions so we strip answers. No direct client access allowed!
      allow read, write: if isAdmin(); 
      // Actually strictly clients should NEVER read. The API doesn't use `request.auth` (it uses firebase-admin), therefore `isAdmin()` here only applies to clients who actually are admins.
      // So admin client CAN read, write questions.
    }

    match /results/{resultId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // Backend API writes the result. Client doesn't.
    }

    match /notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pyqs/{pyqId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /patterns/{patternId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /carousel/{carouselId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

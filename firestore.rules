rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == 'bakolaypan@gmail.com') || (
          exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && (
        isAdmin() || (
          incoming().role == 'user' &&
          (!('totalTestsTaken' in incoming()) || incoming().totalTestsTaken == 0) &&
          (!('cumulativeScore' in incoming()) || incoming().cumulativeScore == 0)
        )
      );

      allow update: if (
        isAdmin() && (
          // Admin can update anything except perhaps keeping it a profile
          true
        )
      ) || (
        isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phoneNumber']) &&
        // Ensure standard users can't change their role
        incoming().role == existing().role
      );
    }

    match /tests/{testId} {
      // Users can only read active tests. Admins can read all.
      // List query must explicitly include `where('isActive', '==', true)`
      allow read: if isSignedIn() && (resource.data.isActive == true || isAdmin());
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      // Backend API handles questions so we strip answers. No direct client access allowed!
      allow read, write: if isAdmin(); 
    }

    match /results/{resultId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // Backend API writes the result. Client doesn't.
    }

    match /notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pyqs/{pyqId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /patterns/{patternId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /carousel/{carouselId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /affairs/{affairId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /practice_sets/{setId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "totalTestsTaken": { "type": "number" },
        "cumulativeScore": { "type": "number" },
        "globalRank": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["role"]
    },
    "Test": {
      "title": "Test",
      "description": "A single Mock Test",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "subjectName": { "type": "string" },
        "category": { "type": "string" },
        "testType": { "type": "string" },
        "duration": { "type": "number" },
        "marksPerCorrect": { "type": "number" },
        "negativeMarks": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "topic", "isActive", "createdAt"]
    },
    "Carousel": {
      "title": "Carousel",
      "description": "Carousel images for home page",
      "type": "object",
      "properties": {
        "link": { "type": "string" },
        "priority": { "type": "number" },
        "createdAt": { "type": "object" },
        "authorId": { "type": "string" }
      },
      "required": ["link", "createdAt", "authorId"]
    },
    "Question": {
      "title": "Question",
      "description": "Question for a Mock Test",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "topic": { "type": "string" },
        "qNo": { "type": "number" },
        "questionText": { "type": "string" },
        "options": { "type": "array" },
        "correctAnswer": { "type": "string" }
      },
      "required": ["testId", "questionText", "options", "correctAnswer"]
    },
    "Result": {
      "title": "Result",
      "description": "Result of a test attempt",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "userId": { "type": "string" },
        "testId": { "type": "string" },
        "score": { "type": "number" },
        "correctAnswers": { "type": "number" },
        "wrongAnswers": { "type": "number" },
        "status": { "type": "string", "enum": ["completed"] }
      },
      "required": ["timestamp", "userId", "testId", "score", "status"]
    },
    "Affair": {
      "title": "Current Affair",
      "description": "Daily current affairs",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "link": { "type": "string" },
        "createdAt": { "type": "object" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "createdAt", "authorId"]
    },
    "PracticeSet": {
      "title": "Practice Set",
      "description": "Practice set PDFs or links",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "link": { "type": "string" },
        "createdAt": { "type": "object" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "createdAt", "authorId"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "User profiles"
    },
    "/tests/{testId}": {
      "schema": { "$ref": "#/entities/Test" },
      "description": "Available tests"
    },
    "/questions/{questionId}": {
      "schema": { "$ref": "#/entities/Question" },
      "description": "Questions for tests"
    },
    "/results/{resultId}": {
      "schema": { "$ref": "#/entities/Result" },
      "description": "Test results"
    },
    "/affairs/{affairId}": {
      "schema": { "$ref": "#/entities/Affair" },
      "description": "Current affairs"
    },
    "/practice_sets/{setId}": {
      "schema": { "$ref": "#/entities/PracticeSet" },
      "description": "Practice sets"
    },
    "/carousel/{carouselId}": {
      "schema": { "$ref": "#/entities/Carousel" },
      "description": "Home page carousel images"
    }
  }
}

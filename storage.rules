rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'Bakolaypan@gmail.com' ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}
